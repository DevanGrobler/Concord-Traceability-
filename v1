// ─── Printing QC Form ─────────────────────────────────────────────────────────
function PrintingQCForm({ onSave }) {
  const [header, setHeader] = useState({ date:today(), shift:"", jobNo:"", customer:"", press:"", operator:"", inspector:"" });
  const [checks, setChecks] = useState(() => QC_CHECKS.map(label=>({ label, result:"", comment:"" })));
  const [overallResult, setOverallResult] = useState("");
  const [remarks, setRemarks] = useState("");
  const [saved, setSaved] = useState(false);
 
  const hSet = (k,v) => setHeader(h=>({...h,[k]:v}));
  const setCheck = (i, k, v) => setChecks(cs=>cs.map((c,idx)=>idx===i?{...c,[k]:v}:c));
 
  const save = async () => {
    await onSave({ type:"printingqc", title:`Printing QC · ${header.jobNo||"(no job)"} · ${header.date}`, header, checks, overallResult, remarks });
    setSaved(true);
  };
 
  const passCount = checks.filter(c=>c.result==="Pass").length;
  const failCount = checks.filter(c=>c.result==="Fail").length;
  const naCount   = checks.filter(c=>c.result==="N/A").length;
 
  if (saved) return <div style={{...S.card,textAlign:"center",padding:60}}><div style={{fontSize:32,marginBottom:12}}>✓</div><div style={{color:C.success,fontSize:16,fontWeight:700}}>Printing QC Saved</div><button style={{...S.btn(),marginTop:20}} onClick={()=>setSaved(false)}>New Sheet</button></div>;
 
  return (
    <div>
      <PageHeader title="Printing QC Form" sub="Complete all 22 QC check items" />
      <SectionCard title="Run Details">
        <Grid cols={4}>
          <Field label="Date"><TInput value={header.date} onChange={v=>hSet("date",v)} type="date" /></Field>
          <Field label="Shift"><TSelect value={header.shift} onChange={v=>hSet("shift",v)} options={["Morning","Afternoon","Night"]} /></Field>
          <Field label="Job No."><TInput value={header.jobNo} onChange={v=>hSet("jobNo",v)} /></Field>
          <Field label="Customer"><TInput value={header.customer} onChange={v=>hSet("customer",v)} /></Field>
          <Field label="Press"><TInput value={header.press} onChange={v=>hSet("press",v)} /></Field>
          <Field label="Operator"><TInput value={header.operator} onChange={v=>hSet("operator",v)} /></Field>
          <Field label="Inspector" col={2}><TInput value={header.inspector} onChange={v=>hSet("inspector",v)} /></Field>
        </Grid>
      </SectionCard>
 
      <SectionCard title={`QC Checks (${passCount} Pass · ${failCount} Fail · ${naCount} N/A)`}>
        <TableHead cols={["#","Check Item","Result","Comments"]} widths={["36px","2fr","140px","2fr"]} />
        {checks.map((c,i)=>(
          <div key={i} style={{display:"grid",gridTemplateColumns:"36px 2fr 140px 2fr",gap:8,padding:"6px 0",borderBottom:`1px solid ${C.border}`,alignItems:"center"}}>
            <div style={{fontSize:11,color:C.muted,textAlign:"center"}}>{i+1}</div>
            <div style={{fontSize:12,color:C.text}}>{c.label}</div>
            <div style={{display:"flex",gap:4}}>
              {["Pass","Fail","N/A"].map(opt=>(
                <button key={opt} onClick={()=>setCheck(i,"result",opt)} style={{
                  flex:1,padding:"5px 0",border:"none",borderRadius:4,cursor:"pointer",fontSize:11,fontWeight:600,fontFamily:"inherit",
                  background: c.result===opt ? (opt==="Pass"?C.success:opt==="Fail"?C.danger:C.muted) : C.bg,
                  color: c.result===opt ? "#fff" : C.muted,
                  outline: c.result===opt ? "none" : `1px solid ${C.border}`,
                  transition:"all 0.1s",
                }}>{opt}</button>
              ))}
            </div>
            <input style={{...S.input,padding:"5px 8px"}} value={c.comment} onChange={e=>setCheck(i,"comment",e.target.value)} placeholder="Add comment…" />
          </div>
        ))}
      </SectionCard>
 
      <SectionCard title="Overall Assessment">
        <div style={{display:"flex",gap:12,marginBottom:16}}>
          {["APPROVED","CONDITIONAL","REJECTED"].map(opt=>(
            <button key={opt} onClick={()=>setOverallResult(opt)} style={{
              flex:1,padding:"12px 0",border:"none",borderRadius:6,cursor:"pointer",fontSize:12,fontWeight:700,fontFamily:"inherit",letterSpacing:"0.04em",
              background: overallResult===opt ? (opt==="APPROVED"?C.success:opt==="REJECTED"?C.danger:C.warn) : C.bg,
              color: overallResult===opt ? "#fff" : C.muted,
              outline: overallResult===opt ? "none" : `1px solid ${C.border}`,
              transition:"all 0.12s",
            }}>{opt}</button>
          ))}
        </div>
        <label style={S.label}>Remarks</label>
        <textarea style={{...S.input,minHeight:80,resize:"vertical"}} value={remarks} onChange={e=>setRemarks(e.target.value)} />
      </SectionCard>
 
      <button style={{...S.btn("accent"),padding:"12px 32px",fontSize:14,marginTop:4}} onClick={save}>Save Printing QC</button>
    </div>
  );
}
 
// ─── Records list ─────────────────────────────────────────────────────────────
function Records({ records, session, onDelete }) {
  const [filter, setFilter] = useState("all");
  const [search, setSearch] = useState("");
  const [expanded, setExpanded] = useState(null);
 
  const filtered = records.filter(r =>
    (filter==="all" || r.type===filter) &&
    (search==="" || r.title.toLowerCase().includes(search.toLowerCase()))
  );
 
  const typeColor = t => t==="production"?C.accent:t==="viscosity"?C.blue:C.success;
  const typeIcon  = t => t==="production"?"▤":t==="viscosity"?"◉":"✓";
 
  return (
    <div>
      <PageHeader title="All Records" sub={`${records.length} total records`} />
      <div style={{display:"flex",gap:10,marginBottom:18,flexWrap:"wrap"}}>
        {["all","production","viscosity","printingqc"].map(f=>(
          <button key={f} onClick={()=>setFilter(f)} style={{...S.btn(filter===f?"accent":"ghost",{padding:"6px 14px",fontSize:11})}}>
            {f==="all"?"All":f==="production"?"Production":f==="viscosity"?"Viscosity QC":"Printing QC"}
          </button>
        ))}
        <input style={{...S.input,width:220,padding:"6px 12px"}} value={search} onChange={e=>setSearch(e.target.value)} placeholder="Search records…" />
      </div>
      {filtered.length===0 && <div style={{color:C.muted,fontSize:13}}>No records found.</div>}
      {filtered.map(r=>(
        <div key={r.id} style={{...S.card,marginBottom:8}}>
          <div style={{display:"flex",alignItems:"center",gap:12,cursor:"pointer"}} onClick={()=>setExpanded(expanded===r.id?null:r.id)}>
            <span style={{fontSize:18,color:typeColor(r.type)}}>{typeIcon(r.type)}</span>
            <div style={{flex:1}}>
              <div style={{fontSize:13,color:C.text,fontWeight:600}}>{r.title}</div>
              <div style={{fontSize:11,color:C.muted}}>{r.createdBy} · {new Date(r.createdAt).toLocaleString()}</div>
            </div>
            <span style={{fontSize:10,color:typeColor(r.type)}}>{expanded===r.id?"▲":"▼"}</span>
            {session.role==="admin" && (
              <button style={S.btn("danger",{padding:"4px 10px",fontSize:11})} onClick={e=>{e.stopPropagation();if(window.confirm("Delete this record?"))onDelete(r.id);}}>Delete</button>
            )}
          </div>
          {expanded===r.id && <RecordDetail record={r} />}
        </div>
      ))}
    </div>
  );
}
 
