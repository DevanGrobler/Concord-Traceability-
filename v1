// ─── User Management ──────────────────────────────────────────────────────────
function UserMgmt({ users, saveUsers, session }) {
  const [form, setForm] = useState({ username:"", password:"", name:"", role:"operator" });
  const [err, setErr] = useState("");
  const fSet = (k,v) => setForm(f=>({...f,[k]:v}));
 
  const addUser = async () => {
    if (!form.username || !form.password || !form.name) { setErr("All fields required."); return; }
    if (users.find(u=>u.username===form.username)) { setErr("Username taken."); return; }
    await saveUsers([...users, { ...form, id: Date.now().toString() }]);
    setForm({ username:"", password:"", name:"", role:"operator" });
    setErr("");
  };
  const deleteUser = async (id) => {
    if (id===session.id) { alert("Cannot delete yourself."); return; }
    await saveUsers(users.filter(u=>u.id!==id));
  };
 
  return (
    <div>
      <PageHeader title="User Management" sub="Add or remove system users" />
      <SectionCard title="Add New User">
        <Grid cols={4}>
          <Field label="Full Name"><TInput value={form.name} onChange={v=>fSet("name",v)} /></Field>
          <Field label="Username"><TInput value={form.username} onChange={v=>fSet("username",v)} /></Field>
          <Field label="Password"><TInput value={form.password} onChange={v=>fSet("password",v)} /></Field>
          <Field label="Role"><TSelect value={form.role} onChange={v=>fSet("role",v)} options={["admin","operator","qc"]} /></Field>
        </Grid>
        {err && <div style={{color:C.danger,fontSize:12,marginTop:8}}>{err}</div>}
        <button style={{...S.btn("accent"),marginTop:12}} onClick={addUser}>Add User</button>
      </SectionCard>
 
      <SectionCard title="Current Users">
        <TableHead cols={["Name","Username","Role","Actions"]} widths={["2fr","1.5fr","1fr","100px"]} />
        {users.map(u=>(
          <div key={u.id} style={{display:"grid",gridTemplateColumns:"2fr 1.5fr 1fr 100px",gap:8,padding:"10px 0",borderBottom:`1px solid ${C.border}`,alignItems:"center"}}>
            <div style={{color:C.text}}>{u.name}</div>
            <div style={{color:C.muted}}>{u.username}</div>
            <span style={{fontSize:10,padding:"2px 8px",borderRadius:4,display:"inline-block",width:"fit-content",background:u.role==="admin"?`${C.accent2}33`:u.role==="qc"?`${C.blue}33`:`${C.success}33`,color:u.role==="admin"?C.accent2:u.role==="qc"?C.blue:C.success}}>{u.role}</span>
            <button style={S.btn("danger",{padding:"4px 10px",fontSize:11})} disabled={u.id===session.id} onClick={()=>deleteUser(u.id)}>Delete</button>
          </div>
        ))}
      </SectionCard>
    </div>
  );
}
 
// ─── Layout helpers ───────────────────────────────────────────────────────────
function SectionCard({ title, children }) {
  return (
    <div style={{...S.card}}>
      <div style={{fontSize:11,fontWeight:700,color:C.muted,letterSpacing:"0.1em",marginBottom:14}}>{title.toUpperCase()}</div>
      {children}
    </div>
  );
}
function Grid({ cols, children }) {
  return <div style={{display:"grid",gridTemplateColumns:`repeat(${cols},1fr)`,gap:12}}>{children}</div>;
}
function TableHead({ cols, widths }) {
  const tpl = widths ? widths.join(" ") : cols.map(()=>"1fr").join(" ");
  return (
    <div style={{display:"grid",gridTemplateColumns:tpl,gap:8,padding:"0 0 6px",borderBottom:`1px solid ${C.border}`,marginBottom:8}}>
      {cols.map(c=><div key={c} style={{fontSize:10,fontWeight:700,color:C.muted,letterSpacing:"0.08em"}}>{c.toUpperCase()}</div>)}
    </div>
  );
}
 
